<% delete_i18n_key = income.recurring_source_id.present? ? "recurring_delete" : "standard_delete" %>
<div id="income_<%= income.id %>" class="flex gap-3 px-4 py-3 hover:bg-white/[0.02] transition-colors">
  <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(0,212,170,0.15);">
    <%= svg_icon "wallet", css_class: "w-4 h-4", stroke: "#00D4AA" %>
  </div>

  <div class="flex-1 min-w-0">
    <%# Top row: description + amount %>
    <div class="flex items-start justify-between gap-2">
      <p class="text-sm font-medium truncate" style="color: #E2E8F0;"><%= income.description %></p>
      <div class="flex items-center gap-2 flex-shrink-0">
        <% if income.recurring? %>
          <%= svg_icon "repeat", css_class: "w-3 h-3 hidden sm:block", stroke: "#8892A4" %>
        <% end %>
        <span class="text-sm font-semibold whitespace-nowrap" style="color: #00D4AA;"><%= format_currency(income.amount) %></span>
      </div>
    </div>

    <%# Bottom row: meta + actions %>
    <div class="flex items-center justify-between gap-2 mt-1">
      <div class="flex items-center gap-1.5 flex-wrap min-w-0">
        <span class="text-xs" style="color: #8892A4;"><%= "#{income.date.day} #{t('date.month_names')[income.date.month]}" %></span>
        <span class="text-xs" style="color: #2A2F45;">·</span>
        <span class="hidden sm:inline"><%= income_type_badge(income.income_type) %></span>
      </div>

      <div class="flex items-center gap-1 flex-shrink-0">
        <%= link_to edit_income_path(income), class: "p-1.5 rounded-lg hover:bg-white/5 transition-colors", style: "color: #8892A4;" do %>
          <%= svg_icon "edit", css_class: "w-3.5 h-3.5" %>
        <% end %>
        <%= render "shared/delete_modal_button",
            path: income_path(income),
            title: t("incomes.income.#{delete_i18n_key}.title"),
            question: t("incomes.income.#{delete_i18n_key}.question"),
            confirm_label: t("incomes.income.#{delete_i18n_key}.confirm"),
            cancel_label: t("shared.delete_modal.cancel"),
            following_label: delete_i18n_key != "standard_delete" ? t("incomes.income.#{delete_i18n_key}.this_and_following") : nil %>
      </div>
    </div>
  </div>
</div>
